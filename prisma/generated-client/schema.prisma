// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "./generated-client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String
  role         Role     @default(USER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]
}

enum Role {
  ADMIN
  USER
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Parâmetros globais do sistema (configuráveis pelo Admin)
model ConfiguracaoGlobal {
  id        String   @id @default(cuid())
  chave     String   @unique
  valor     String
  descricao String?
  updatedAt DateTime @updatedAt
}

// Dados de distribuição por módulo (persistência no banco)
model Ala {
  id        String       @id @default(cuid())
  nome      String       @unique
  ordem     Int          @default(0)
  ativa     Boolean      @default(true)
  createdAt DateTime     @default(now())
  distribs  DistribAla[]
}

model DistribAla {
  id        String   @id @default(cuid())
  modulo    Modulo
  alaId     String
  ala       Ala      @relation(fields: [alaId], references: [id], onDelete: Cascade)
  internos  Int      @default(0)
  dietas    Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([modulo, alaId])
}

enum Modulo {
  ALIMENTACAO
  CAFE
  BISCOITO
}

model Ocorrencia {
  id        String   @id @default(cuid())
  titulo    String
  categoria String
  icone     String   @default("📋")
  texto     String
  servidor  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OcorrenciaCategoria {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
}
